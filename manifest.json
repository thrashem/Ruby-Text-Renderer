{
  "manifest_version": 3,
  "name": "Ruby Text Renderer",
  "version": "1.0",
  "description": "Renders [text]{ruby} syntax as ruby text on user-specified sites.",
  "permissions": ["storage", "tabs", "activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
